# Supabase — copy this file to .env.local and fill in the real values.
# Get both from your Supabase dashboard: Project Settings → API.
# The anon key is public by design — security comes from Row Level Security, not secrecy.

VITE_SUPABASE_URL=your-project-url
VITE_SUPABASE_ANON_KEY=your-anon-public-key
